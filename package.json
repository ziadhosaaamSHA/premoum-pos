{
  "name": "frontend-next",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.cjs",
  "productName": "Premium POS",
  "description": "Premium POS desktop application",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:vercel": "sh scripts/vercel-build.sh",
    "start": "next start",
    "lint": "eslint",
    "desktop:dev": "node desktop/scripts/dev.mjs",
    "desktop:build:next": "node desktop/scripts/build-next.mjs",
    "desktop:pack": "npm run desktop:build:next && electron-builder --dir",
    "desktop:dist": "npm run desktop:build:next && electron-builder",
    "desktop:dist:mac": "npm run desktop:build:next && electron-builder --mac",
    "desktop:dist:win": "npm run desktop:build:next && electron-builder --win",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "jose": "^6.1.3",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "prisma": "^7.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "build": {
    "appId": "com.premiumpos.desktop",
    "productName": "Premium POS",
    "asar": false,
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      ".next/standalone/**",
      "desktop/**",
      "prisma/**",
      "prisma.config.ts",
      "package.json",
      "node_modules/dotenv/**",
      "node_modules/electron-updater/**",
      "node_modules/builder-util-runtime/**",
      "node_modules/lazy-val/**",
      "node_modules/semver/**",
      "node_modules/prisma/**",
      "node_modules/@prisma/**"
    ],
    "extraResources": [
      {
        "from": ".next/standalone/.next/node_modules",
        "to": "app/.next/standalone/.next/node_modules"
      },
      {
        "from": ".next/standalone/node_modules/.prisma",
        "to": "app/.next/standalone/node_modules/.prisma"
      },
      {
        "from": "prisma",
        "to": "prisma"
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ziadhosaaamSHA",
        "repo": "premoum-pos"
      }
    ]
  }
}
